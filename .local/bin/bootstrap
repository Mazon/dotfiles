#!/usr/bin/env bash
#
# bootstrap — install all dependencies tracked in dotfiles.
# Supports: Arch Linux (pacman + AUR).
#
# Usage:
#   chmod +x ~/.local/bin/bootstrap
#   ~/.local/bin/bootstrap
#
# What it installs:
#   - Shell/editor:   fish, neovim, tmux, starship, fzf, fd, bat, zoxide
#   - Terminal/font:  alacritty, nerd fonts (Iosevka)
#   - TUI:            btop, htop
#   - Dev tools:      git, tmux-plugin-manager, gitmux
#   - Browser:        librewolf (AUR)
#   - Apps:           signal-desktop
#
#   Wayland/mango compositor:
#     mango-wm, waybar, wlogout, swaync, fuzzel, swaybg,
#     swaylock, swayidle, swayosd, sway-audio-idle-inhibit,
#     wl-clip-persist, cliphist, wl-paste, wlsunset, wlr-randr,
#     dimland, grim, slurp, swappy, pamixer, playerctl,
#     blueman, network-manager-applet, xfce-polkit, fcitx5,
#     Bibata-Modern-Ice cursor theme

set -euo pipefail

# ── helpers ────────────────────────────────────────────────────────────────────
GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'

info()  { printf "${GREEN}[+]${NC} %s\n" "$*"; }
warn()  { printf "${YELLOW}[!]${NC} %s\n" "$*"; }
err()   { printf "${RED}[✗]${NC} %s\n" "$*"; }

has() { command -v "$1" &>/dev/null; }

# ── detect OS ──────────────────────────────────────────────────────────────────
if [[ ! -f /etc/arch-release ]]; then
    err "Unsupported OS. Only Arch Linux is supported."
    exit 1
fi

info "Detected OS: Arch Linux"

# ── package manager setup ──────────────────────────────────────────────────────
setup_pacman() {
    info "Updating pacman..."
    sudo pacman -Syu --noconfirm
}

# ── AUR helper (paru) ──────────────────────────────────────────────────────────
install_paru() {
    if has paru; then
        info "paru already installed."
        return 0
    fi
    info "Installing paru (AUR helper)..."
    local tmpdir
    tmpdir=$(mktemp -d)
    git clone https://aur.archlinux.org/paru-bin.git "$tmpdir/paru-bin"
    (cd "$tmpdir/paru-bin" && makepkg -si --noconfirm)
    rm -rf "$tmpdir"
}

# ── install functions ──────────────────────────────────────────────────────────

install_arch() {
    # ── Core CLI tools ─────────────────────────────────────────────────────
    local cli=(
        fish
        neovim
        tmux
        starship
        fzf
        fd
        bat
        zoxide
        eza
        gitmux
        btop
        git
        curl
        jq
        ripgrep
        unzip
        tar
        gdu
        nodejs
        base-devel
    )
    info "Installing core CLI tools..."
    sudo pacman -S --needed --noconfirm "${cli[@]}"

    # ── Terminal & fonts ───────────────────────────────────────────────────
    local terminal=(
        kitty
        ttf-iosevka-nerd
    )
    info "Installing terminal & fonts..."
    sudo pacman -S --needed --noconfirm "${terminal[@]}"

    # ── Wayland / mango compositor stack ───────────────────────────────────
    local wayland=(
        # compositor
        mango-wm

        # bar & UI
        waybar
        wlogout
        swaync
        fuzzel

        # wallpaper & lock
        swaybg
        swaylock
        swayidle

        # OSD & audio idle
        swayosd
        sway-audio-idle-inhibit

        # clipboard
        wl-clip-persist
        cliphist
        wl-clipboard

        # night light & display
        wlsunset
        wlr-randr
        dimland

        # screenshots
        grim
        slurp
        swappy

        # audio
        pamixer
        playerctl
        wireplumber

        # system tray applets
        blueman
        network-manager-applet
        xfce-polkit

        # input method
        fcitx5
        fcitx5-gtk
        fcitx5-qt
        fcitx5-configtool

        # cursor theme
        bibata-cursor-theme
    )
    info "Installing Wayland/mango compositor stack..."
    # Install what's available; skip packages not in official repos
    for pkg in "${wayland[@]}"; do
        if pacman -Si "$pkg" &>/dev/null; then
            sudo pacman -S --needed --noconfirm "$pkg"
        else
            warn "Skipping '$pkg' (not in repos — may need AUR)"
        fi
    done

    # ── Apps (official repos) ─────────────────────────────────────────────
    local apps=(
        signal-desktop
        thunderbird
        darktable
        qalc
        keepassxc
        flameshot
        gnupg
        xorg-xrdb
        steam
        mpv
    )
    info "Installing apps..."
    for pkg in "${apps[@]}"; do
        if pacman -Si "$pkg" &>/dev/null; then
            sudo pacman -S --needed --noconfirm "$pkg"
        else
            warn "Skipping '$pkg' (not in repos — may need AUR)"
        fi
    done

    # ── pi.dev coding agent ───────────────────────────────────────────────
    info "Installing pi.dev coding agent..."
    npm install -g @earendil-works/pi-coding-agent

    # ── Apps (AUR) ─────────────────────────────────────────────────────────
    local aur_apps=(
        librewolf-bin
        himalaya-bin
    )
    info "Installing AUR apps via paru..."
    paru -S --needed --noconfirm "${aur_apps[@]}"
}

# ── tmux plugin manager ────────────────────────────────────────────────────────
install_tpm() {
    local tpm_dir="$HOME/.tmux/plugins/tpm"
    if [[ -d "$tpm_dir" ]]; then
        info "tpm already installed, updating..."
        (cd "$tpm_dir" && git pull -q)
    else
        info "Installing tmux plugin manager (tpm)..."
        git clone https://github.com/tmux-plugins/tpm "$tpm_dir"
    fi
}

# ── fish as default shell ─────────────────────────────────────────────────────
set_fish_default() {
    local fish_path
    fish_path=$(command -v fish)
    if ! grep -q "$fish_path" /etc/shells 2>/dev/null; then
        info "Adding fish to /etc/shells..."
        echo "$fish_path" | sudo tee -a /etc/shells
    fi
    if [[ "$SHELL" != *"fish"* ]]; then
        info "Setting fish as default shell..."
        sudo chsh -s "$fish_path" "$USER"
    fi
}

# ── shell aliases (fish) ──────────────────────────────────────────────────────
setup_aliases() {
    local fish_dir="$HOME/.config/fish"
    mkdir -p "$fish_dir"
    local aliases_file="$fish_dir/conf.d/aliases.fish"

    info "Setting up shell aliases..."
    cat > "$aliases_file" << 'EOF'
# ── Modern tool aliases ───────────────────────────────────────────────────
alias cat="bat --paging=never"
alias ls="eza"
alias ll="eza -l --icons"
alias la="eza -la --icons"
alias lt="eza --tree --level=2"
alias find="fd"
alias grep="rg"

# zoxide replaces cd (init adds z, zi commands and wraps cd)
zoxide init fish | source
EOF
    info "Aliases written to $aliases_file"
}

# ── clone dotfiles if missing ─────────────────────────────────────────────────
clone_dotfiles() {
    if [[ ! -d "$HOME/.dotfiles" ]]; then
        info "Cloning dotfiles bare repo..."
        git clone --bare git@github.com:Mazon/dotfiles.git "$HOME/.dotfiles"
        git --git-dir="$HOME/.dotfiles" --work-tree="$HOME" checkout
        git --git-dir="$HOME/.dotfiles" --work-tree="$HOME" config status.showUntrackedFiles no
        info "Dotfiles checked out."
    else
        info "Dotfiles repo already present."
    fi
}

# ── main ───────────────────────────────────────────────────────────────────────

main() {
    info "=== Bootstrapping system ==="

    # 1. Clone dotfiles first so configs are in place
    clone_dotfiles

    # 2. Package manager
    setup_pacman

    # 3. Install AUR helper
    install_paru

    # 4. Install packages
    install_arch

    # 5. Cross-platform setup
    install_tpm

    # 7. Optional: set fish as default shell
    if ! has fish; then
        warn "fish not found, skipping default shell setup"
    else
        read -rp "$(printf "${YELLOW}Set fish as default shell? [y/N]${NC} ")" answer
        if [[ "$answer" =~ ^[Yy]$ ]]; then
            set_fish_default
        fi
    fi

    # 8. Shell aliases
    setup_aliases

    # 9. Install tmux plugins
    info "Installing tmux plugins..."
    "$HOME/.tmux/plugins/tpm/bin/install_plugins"

    info "=== Done! ==="
    info "Log out/in or restart to pick up all changes."
}

main "$@"
