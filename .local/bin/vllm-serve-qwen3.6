#!/usr/bin/env bash
# Serve the local Qwen3.6-27B-Text-NVFP4-MTP model with vLLM on an RTX 5090 (32 GB).
#
# This model is a qwen3_5 DeltaNet HYBRID (48 linear-attn + 16 full-attn layers),
# quantized NVFP4 by ModelOpt. Two things dominate throughput on this setup:
#
#   1. CUDA graph capture MUST be enabled — the NVFP4 CUTLASS GEMMs only hit
#      steady state inside a captured graph. Running eager is ~3-5x slower.
#   2. DeltaNet hybrids make vLLM's KV-cache profiler miscount the Triton
#      autotune peak as persistent KV demand, over-reserve memory, and OOM
#      *during* graph capture. The fix is to PIN kv-cache-memory-bytes low.
#      Only the 16 full-attn layers hold KV: at fp8 a full 8192-ctx sequence
#      is just 0.25 GiB, so 2 GiB = ~64 concurrent max-ctx sequences.
#
set -euo pipefail

MODEL_DIR="${HOME}/llama/models/Qwen3.6-27B-Text-NVFP4-MTP"
SERVED_NAME="sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP"

if [[ ! -d "$MODEL_DIR" ]]; then
  echo "Model directory not found: $MODEL_DIR" >&2
  exit 1
fi

# Reduce fragmentation during graph capture / autotune transients.
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

exec vllm serve "$MODEL_DIR" \
  --served-model-name "$SERVED_NAME" \
  --trust-remote-code \
  --gpu-memory-utilization 0.90 \
  --max-model-len 8192 \
  --max-num-seqs 8 \
  --language-model-only \
  --quantization modelopt \
  --kv-cache-dtype fp8 \
  --kv-cache-memory-bytes 2147483648 \
  --enable-prefix-caching \
  --reasoning-parser qwen3 \
  --enable-auto-tool-choice \
  --tool-call-parser qwen3_xml \
  --speculative-config '{"method":"qwen3_5_mtp","num_speculative_tokens":3}'
