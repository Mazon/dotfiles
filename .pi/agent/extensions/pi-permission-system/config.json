{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-permission-system/main/schemas/permissions.schema.json",
  "debugLog": false,
  "permissionReviewLog": false,
  "yoloMode": false,

  "permission": {
    "*": "ask",
    "path": { "*": "allow" },

    "read": "allow",
    "grep": "allow",
    "find": "allow",
    "ls": "allow",

    "write": "ask",
    "edit": "ask",

    "ask_user": "allow",
    "ask_*": "allow",

    "TaskCreate": "allow",
    "TaskList": "allow",
    "TaskGet": "allow",
    "TaskUpdate": "allow",
    "TaskOutput": "allow",
    "TaskStop": "allow",
    "TaskExecute": "allow",
    "get_subagent_result": "allow",
    "parse_plan_waves": "allow",

    "bash": {
      "*": "ask",
      "cd *": "allow",
      "git *": "ask",
      "diff *": "allow",
      "echo *": "ask",
      "tree *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "fd *": "allow",
      "fd -x *": "ask",
      "fd --exec *": "ask",
      "fd -X *": "ask",
      "fd --exec-batch *": "ask",
      "cat *": "allow",
      "ag *": "allow",
      "grep *": "allow",
      "ls *": "allow",
      "rg *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "cut *": "allow",
      "tr *": "allow",
      "paste *": "allow",
      "column *": "allow",
      "comm *": "allow",
      "join *": "allow",
      "awk *": "ask",
      "jq *": "allow",
      "yq *": "allow",
      "bat *": "allow",
      "printf *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "df *": "allow",
      "realpath *": "allow",
      "readlink *": "allow",
      "basename *": "allow",
      "dirname *": "allow",
      "md5sum *": "allow",
      "sha256sum *": "allow",
      "sha1sum *": "allow",
      "xxd *": "allow",
      "hexdump *": "allow",
      "base64 *": "allow",
      "od *": "allow",
      "pwd": "allow",
      "whoami": "allow",
      "uname *": "allow",
      "date *": "allow",
      "uptime": "allow",
      "hostname": "allow",
      "which *": "allow",
      "type *": "allow",
      "env": "allow",
      "printenv *": "allow",
      "id": "allow",
      "seq *": "allow",
      "test *": "allow",
      "rm -rf *": "deny",
      "sudo *": "deny"
    },

    "mcp": { "*": "ask" },
    "skill": { "*": "ask" },
    "external_directory": "ask"
  }
}
