{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-permission-system/main/schemas/permissions.schema.json",
  "debugLog": false,
  "permissionReviewLog": false,
  "yoloMode": false,
  "permission": {
    "*": "ask",
    "read": "allow",
    "grep": "allow",
    "find": "allow",
    "ls": "allow",
    "write": "ask",
    "edit": "ask",
    "ask_user": "allow",
    "ask_*": "allow",
    "TaskCreate": "allow",
    "TaskList": "allow",
    "TaskGet": "allow",
    "TaskUpdate": "allow",
    "TaskOutput": "allow",
    "TaskStop": "allow",
    "TaskExecute": "allow",
    "get_subagent_result": "allow",
    "parse_plan_waves": "allow",
    "nvim_apply_edit": "allow",
    "path": {
      "*": "allow",

      "/dev/**": "ask",
      "/dev/null": "allow",
      "/dev/zero": "allow",
      "/dev/full": "allow",
      "/dev/random": "allow",
      "/dev/urandom": "allow",
      "/dev/stdin": "allow",
      "/dev/stdout": "allow",
      "/dev/stderr": "allow",

      "~/.ssh/**": "ask",
      "~/.gnupg/**": "ask",
      "~/.aws/**": "ask",
      "~/.config/gcloud/**": "ask",
      "~/.docker/**": "ask",
      "~/.kube/**": "ask",
      "~/.netrc": "ask",
      "~/.npmrc": "ask",
      "~/.pypirc": "ask",
      "~/.bashrc": "ask",
      "~/.bash_profile": "ask",
      "~/.bash_login": "ask",
      "~/.bash_logout": "ask",
      "~/.bash_aliases": "ask",
      "~/.bash_history": "ask",
      "~/.inputrc": "ask",
      "~/.profile": "ask",
      "~/.zshrc": "ask",
      "~/.zprofile": "ask",
      "~/.zshenv": "ask",
      "~/.zlogin": "ask",
      "~/.tmux.conf": "ask",
      "~/.vimrc": "ask",
      "~/.gitconfig": "ask",
      "/etc/passwd": "ask",
      "/etc/shadow": "ask",
      "/etc/gshadow": "ask",
      "/etc/group": "ask",
      "/etc/sudoers": "ask",
      "/etc/sudoers.d/**": "ask",
      "/etc/pam.d/**": "ask",
      "/etc/ssh/**": "ask",
      "/etc/profile": "ask",
      "/etc/profile.d/**": "ask",
      "/etc/bashrc": "ask",
      "/etc/bash.bashrc": "ask",
      "/etc/crontab": "ask",
      "/etc/cron.d/**": "ask",
      "/etc/cron.daily/**": "ask",
      "/etc/cron.hourly/**": "ask",
      "/boot/**": "ask",
      "*.env": "ask",
      "*.env.*": "ask"
    },

    "bash": {
      "*": "ask",

      "cd *": "allow",
      "diff *": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "tree *": "allow",
      "tee *": "allow",
      "cat *": "allow",
      "bat *": "allow",
      "sed *": "allow",
      "grep *": "allow",
      "ag *": "allow",
      "rg *": "allow",
      "ls *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "cut *": "allow",
      "tr *": "allow",
      "paste *": "allow",
      "column *": "allow",
      "comm *": "allow",
      "join *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "awk *": "allow",
      "jq *": "allow",
      "yq *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "df *": "allow",
      "realpath *": "allow",
      "readlink *": "allow",
      "basename *": "allow",
      "dirname *": "allow",
      "md5sum *": "allow",
      "sha256sum *": "allow",
      "sha1sum *": "allow",
      "xxd *": "allow",
      "hexdump *": "allow",
      "base64 *": "allow",
      "od *": "allow",
      "pwd": "allow",
      "whoami": "allow",
      "id": "allow",
      "uname *": "allow",
      "date *": "allow",
      "uptime": "allow",
      "hostname": "allow",
      "which *": "allow",
      "type *": "allow",
      "seq *": "allow",
      "test *": "allow",
      "head *": "allow",
      "true": "allow",
      "bwrap *": "allow",
      "ps *": "allow",
      "pgrep *": "allow",


      "git *": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git blame *": "allow",
      "git grep *": "allow",
      "git ls-files *": "allow",
      "git rev-parse *": "allow",
      "git describe *": "allow",
      "git branch": "allow",
      "git branch -a*": "allow",
      "git branch -r*": "allow",
      "git branch -v*": "allow",
      "git tag": "allow",
      "git tag -l*": "allow",
      "git remote": "allow",
      "git remote -v*": "allow",
      "git config --get*": "allow",
      "git config --list*": "allow",
      "git config -l*": "allow",
      "git stash list*": "allow",
      "git reflog": "allow",
      "git reflog show *": "allow",
      "git check-ignore": "allow",

      "find *": "allow",
      "find*-exec*": "ask",
      "find*-ok*": "ask",
      "find*-delete*": "ask",
      "find*-fls*": "ask",
      "find*-fprint*": "ask",

      "fd *": "allow",
      "fd*-x*": "ask",
      "fd*-X*": "ask",
      "fd*--exec*": "ask",


      "rm -rf *": "deny",
      "sudo *": "deny",
      "doas *": "deny",
      "su *": "deny",
      "pkexec *": "deny"
  },
"mcp": { "*": "ask" },
"skill": { "*": "ask" },
"external_directory": {
  "*": "ask",
  "/opt/homebrew/bin/bash": "allow",
  "/opt/homebrew/Cellar/bash/*/bin/bash": "allow",
  "/tmp": "allow"
}
}
}
