{
  "enabled": true,
  "network": {
    "allowedDomains": [
      "npmjs.org",
      "*.npmjs.org",
      "registry.npmjs.org",
      "registry.yarnpkg.com",
      "pypi.org",
      "*.pypi.org",
      "github.com",
      "*.github.com",
      "api.github.com",
      "raw.githubusercontent.com"
    ],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": [
      "~/.ssh",
      "~/.aws",
      "~/.gnupg",
      "~/.config",
      "~/.kube",
      "~/.docker",
      "~/.netrc",
      "~/.gitconfig"
    ],
    "allowWrite": [".", "/tmp"],
    "denyWrite": [
      ".env",
      ".env.*",
      "*.pem",
      "*.key",
      "*.p12",
      "*.jks",
      "*.keystore",
      "id_rsa*",
      "id_ed25519*",
      "authorized_keys",
      "known_hosts"
    ]
  }
}
