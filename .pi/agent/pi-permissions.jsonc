{
  // NOTE: Agent-level permission sections (in agents/*.md) REPLACE these defaults, they do NOT merge.
  // If an agent defines a `bash:` or `skills:` section, the global defaults for that section are ignored.
  // Global permission policy for pi-permission-system
  // Allows read-only tools by default, prompts for destructive operations
  "defaultPolicy": {
    "bash": "ask",
    "tools": "ask",
    "mcp": "ask",
    "skills": "ask",
    "special": "ask"
  },
  "bash": {
    "*": "ask",
    "cd *": "allow",
    "git *": "allow",
    "diff *": "allow",
    "echo *": "allow",
    "tree *": "allow",
    "sort *": "allow",
    "uniq *": "allow",
    "fd *": "allow",
    "cat *": "allow",
    "ag *": "allow",
    "grep *": "allow",
    "ls *": "allow",
    "find *": "allow"
  },
  "tools": {
    "*": "ask",
    // Read-only tools — always allowed
    "read": "allow",
    "grep": "allow",
    "find": "allow",
    "ls": "allow",
    "parse_plan_waves": "allow",
    // Task tools — always allowed
    "TaskCreate": "allow",
    "TaskList": "allow",
    "TaskGet": "allow",
    "TaskUpdate": "allow",
    "TaskOutput": "allow",
    "TaskStop": "allow",
    "TaskExecute": "ask",
    "get_subagent_*": "allow",
    "Agent": "ask",
    // Destructive tools — require confirmation
    "write": "ask",
    "edit": "ask"
  },
  "skills": {
    "*": "ask",
    "consult": "allow"
  }
}
