{
  "enabled": true,
  "network": {
    "allowedDomains": ["localhost","127.0.0.1"],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": [
      ".env",
      ".env.*",
      ".env.local",
      ".env.development",
      ".env.production",
      ".env.staging",
      ".env.test",
      ".env.*.local",
      "*.env",
      "~/.ssh",
      "~/.ssh/",
      "~/.aws",
      "~/.aws/",
      "~/.gnupg",
      "~/.gnupg/",
      "~/.config",
      "~/.config/gcloud/",
      "*-credentials.json",
      "*serviceAccount*.json",
      "*service-account*.json",
      "~/.azure/",
      "~/.kube/",
      "kubeconfig",
      "*-secret.yaml",
      "secrets.yaml",
      "~/.docker/",
      "*.pem",
      "*.key",
      "*.p12",
      "*.pfx",
      "*.tfstate",
      "*.tfstate.backup",
      ".terraform/",
      ".vercel/",
      ".netlify/",
      "firebase-adminsdk*.json",
      "serviceAccountKey.json",
      ".supabase/",
      "~/.netrc",
      "~/.npmrc",
      "~/.pypirc",
      "~/.git-credentials",
      ".git-credentials",
      "dump.sql",
      "backup.sql",
      "*.dump"
    ],
    "allowRead": [],
    "allowWrite": [".", "/tmp", "~/.npm", "~/.cache", "~/.cargo/registry", "~/.gradle/caches", "~/.m2/repository"],
    "denyWrite": [".env", ".env.*", "*.pem", "*.key",
                  "~/.bashrc", "~/.zshrc", "~/.profile", "~/.bash_profile",
                  "~/.ssh", "~/.gitconfig",
                  "~/Library/LaunchAgents", "~/Library/LaunchDaemons"]
  }
}

